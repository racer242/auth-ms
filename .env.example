# App
NODE_ENV=development
APP_PORT=3000
APP_PREFIX=api/v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=auth_service
DB_USER=postgres
DB_PASSWORD=secret
DB_POOL_SIZE=10
DB_SSL=false

# Redis
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=300

# JWT
JWT_ACCESS_SECRET=super-secret-access-key-that-is-at-least-64-characters-long-for-security-purposes
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_SECRET=super-secret-refresh-key-that-is-at-least-64-characters-long-for-security-purposes
JWT_REFRESH_EXPIRY=604800
JWT_REFRESH_EXPIRY_REMEMBER=2592000

# Security
ARGON2_MEMORY=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4

# Rate Limit
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
AUTH_THROTTLE_LOGIN_TTL=60000
AUTH_THROTTLE_LOGIN_LIMIT=5

# Swagger
SWAGGER_ENABLED=true
SWAGGER_TITLE=Auth Microservice API
SWAGGER_VERSION=1.0
